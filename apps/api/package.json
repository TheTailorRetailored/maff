{
  "name": "@maff/api",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:baseline:v2": "prisma migrate resolve --applied 20260509000000_maff_v2_runtime",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node dist/smoke.js",
    "test:smoke:src": "tsx src/smoke.ts",
    "test:smoke:db": "tsx src/smokeRuntimeDb.ts",
    "admin:reset-legacy": "node dist/admin/resetLegacyResearch.js",
    "admin:reset-legacy:src": "tsx src/admin/resetLegacyResearch.ts",
    "admin:reset-research": "node dist/admin/resetResearchWorkspace.js",
    "admin:reset-research:src": "tsx src/admin/resetResearchWorkspace.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jose": "^5.9.6",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.6",
    "prisma": "^5.22.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  }
}
