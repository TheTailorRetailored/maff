generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceType {
  private
  shared
}

enum WorkspaceRole {
  owner
  editor
  viewer
  admin
}

enum JobType {
  quartz_build
  lean_check
  lean_stub
  lean_proof_attempt
  index_rebuild
}

enum JobStatus {
  queued
  running
  succeeded
  failed
  cancelled
}

enum ProjectStatus {
  seed
  active
  paused
  completed
  archived
}

enum ProjectGoalStatus {
  proposed
  approved
  active
  blocked
  completed
  abandoned
}

enum WorkstreamKind {
  project_coordination
  literature_review
  proof_route_generation
  proof_attempt
  counterexample_search
  experiment_design
  computation
  hostile_review
  gap_analysis
  formalization
  lean_check
  paper_synthesis
  triage
}

enum WorkstreamStatus {
  planned
  ready
  claimed
  running
  blocked
  needs_review
  revision_required
  approved
  completed
  abandoned
  escalated
}

enum AgentRole {
  ProjectCoordinator
  WorkstreamCoordinator
  LiteratureAgent
  ProofRouteAgent
  ProofAttemptAgent
  CounterexampleAgent
  ExperimentAgent
  CodingAgent
  GapAnalyst
  HostileReviewer
  FormalizationAgent
  LeanChecker
  PaperWriter
  TriageAgent
}

enum AgentRunStatus {
  started
  running
  submitted
  failed
  escalated
  cancelled
}

enum AgentMessageKind {
  instruction
  update
  blocker
  handoff
  user_steering
  escalation
  review_request
}

enum WorkstreamReportStatus {
  draft
  submitted
  reviewed_needs_revision
  reviewed_approved
  superseded
}

enum ReviewVerdict {
  approved
  needs_revision
  rejected
  blocked
  escalate
}

/// Approval is deliberately scoped: no value is a transitive mathematical approval.
enum ReviewType {
  legacy_unspecified
  ingredient_correctness
  proof_integration
  end_to_end_mathematical
  novelty
  bibliography
  editorial
  source_fidelity
  compile
  numerical_verification
  formal_verification
  other
}

enum ReviewIndependence {
  author_self_check
  same_workstream_reviewer
  independent_reviewer
  external_referee_style
}

/// Candidate manuscripts are not canonical mathematical working papers until their ledger is complete.
enum ManuscriptVerificationState {
  unverified_candidate
  ledger_complete
  mathematically_reviewed
}

enum ManuscriptFreezeLevel {
  none
  lexical
  interface
  mathematical
}

enum ExternalReviewProvenance {
  human
  journal_referee
  fresh_external_ai_chat
  internal_maff_agent
  unknown
}

enum StrategicReviewVerdict {
  continue
  continue_with_rebase
  split
  pivot
  pause
  terminate
}

enum BranchState {
  mainline
  exploratory
  paused
  killed
  spinout_candidate
}

enum ArtifactKind {
  markdown
  latex
  code
  computation_output
  lean_file
  pdf
  external_reference
  dataset
  image
  other
}

enum ArtifactStorageStatus {
  available
  missing
  corrupt
}

enum ResearchArtifactFileStatus {
  not_applicable
  provenance_only
  requires_regeneration
  durable
}

enum MathObjectType {
  definition
  object
  construction
  notation
}

enum ClaimKind {
  conjecture
  theorem
  lemma
  proposition
  corollary
  reduction
  equivalence
  bound
  counterexample_claim
}

enum ClaimStatus {
  unexamined
  conjectured
  under_attack
  has_routes
  proof_attempted
  gap_found
  informal_proof_candidate
  reviewed_informal_proof
  formalization_target
  lean_checked
  lean_verified
  refuted
  archived
}

enum ProofRouteStatus {
  proposed
  active
  blocked
  failed
  promoted
  abandoned
}

enum ProofAttemptStatus {
  draft
  failed
  gap_found
  candidate
  reviewed
  rejected
}

enum GapSeverity {
  cosmetic
  minor
  major
  fatal
  unknown
}

enum GapStatus {
  open
  assigned
  resolved
  abandoned
}

enum CounterexampleStatus {
  candidate
  verified
  refuted
  inconclusive
}

enum ExperimentStatus {
  planned
  running
  completed
  inconclusive
  failed
}

enum KnownResultStatus {
  suspected
  cited
  checked
  disputed
}

enum AssumptionStatus {
  hypothesis
  unproved_dependency
  temporary_axiom
  known_mathlib_result
  proved_locally
  discharged
}

enum FormalizationTargetStatus {
  proposed
  active
  blocked
  completed
  abandoned
}

enum LeanTheoremStatus {
  draft
  lean_checked
  lean_verified
  failed
  blocked
}

enum GraphEdgeType {
  depends_on
  supports
  contradicts
  refutes
  formalizes
  cites
  produced_by
  reviewed_by
  blocks
  resolves
  assigned_to
  reports_on
  derived_from
  parent_of
}

enum ResearchConfidence {
  low
  medium
  high
}

enum MechanismStatus {
  seed
  explored
  active
  reusable
  killed
  archived
}

enum MechanismMaturity {
  seed
  sketched
  tested
  sharpened
  usable
  paper_ready
}

enum SpinoutStatus {
  seed
  plausible
  active
  promoted
  killed
  archived
}

enum AssumptionRegimeStatus {
  seed
  active
  deprecated
  impossible
  archived
}

enum TheoremContractStatus {
  draft
  active
  narrowed
  proved_informally
  refuted
  paused
  archived
}

enum ResearchArtifactKind {
  paper_draft
  proof_skeleton
  survey_memo
  verification_script
  experiment_notebook
  counterexample_catalogue
  formalization_stub
  lean_stub
  theorem_map
  exposition_note
  migration_report
  other
}

enum ResearchArtifactStatus {
  draft
  active
  reviewed
  archived
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  auth0Sub    String?  @unique
  email       String?
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships         WorkspaceMember[]
  jobs                Job[]             @relation("JobCreator")
  auditLogs           AuditLog[]
  tasks               TaskIndex[]       @relation("AssignedTasks")
  ownedWorkspaces     Workspace[]       @relation("WorkspaceOwner")
  createdProjects     Project[]         @relation("ProjectCreator")
  approvedGoals       ProjectGoal[]     @relation("GoalApprover")
  assignedWorkstreams Workstream[]      @relation("AssignedWorkstreams")
  identities          UserIdentity[]
}

model UserIdentity {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  issuer    String
  subject   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([issuer, subject])
  @@index([userId])
}

model Workspace {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique
  name        String
  type        WorkspaceType
  ownerUserId String?       @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner                      User?                       @relation("WorkspaceOwner", fields: [ownerUserId], references: [id])
  members                    WorkspaceMember[]
  nodes                      NodeIndex[]
  edges                      EdgeIndex[]
  tasks                      TaskIndex[]
  jobs                       Job[]
  auditLogs                  AuditLog[]
  localTheorems              LocalTheorem[]
  projects                   Project[]
  projectGoals               ProjectGoal[]
  workstreams                Workstream[]
  agentRuns                  AgentRun[]
  agentMessages              AgentMessage[]
  workstreamReports          WorkstreamReport[]
  reviewRounds               ReviewRound[]
  artifacts                  Artifact[]
  artifactManuscriptVersions ArtifactManuscriptVersion[]
  mathObjects                MathObject[]
  claims                     Claim[]
  proofRoutes                ProofRoute[]
  proofAttempts              ProofAttempt[]
  gaps                       Gap[]
  counterexamples            Counterexample[]
  experiments                Experiment[]
  papers                     Paper[]
  knownResults               KnownResult[]
  assumptions                Assumption[]
  formalizationTargets       FormalizationTarget[]
  leanTheorems               LeanTheorem[]
  graphEdges                 GraphEdge[]
  researchDeltas             ResearchDelta[]
  mechanisms                 Mechanism[]
  spinoutCandidates          SpinoutCandidate[]
  assumptionRegimes          AssumptionRegime[]
  theoremContracts           TheoremContract[]
  frontierSnapshots          ResearchFrontierSnapshot[]
  researchArtifacts          ResearchArtifact[]
  manuscriptVersions         ManuscriptVersion[]
  proofObligations           ProofObligation[]
  reviewObligationChecks     ReviewObligationCheck[]
  workstreamDependencies     WorkstreamDependency[]
  externalReviewImports      ExternalReviewImport[]
  projectEpochs              ProjectEpoch[]
  projectSubstantiveActions  ProjectSubstantiveAction[]
  strategicReviews           StrategicReviewRound[]
  projectBranches            ProjectBranch[]
  researchLinks              ResearchLink[]
}

model WorkspaceMember {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model NodeIndex {
  id                       String    @id @default(uuid()) @db.Uuid
  workspaceId              String    @db.Uuid
  nodeId                   String
  slug                     String
  title                    String
  type                     String
  status                   String
  area                     String?
  path                     String
  metadata                 Json
  bodyPreview              String
  createdAtFromFrontmatter DateTime?
  updatedAtFromFrontmatter DateTime?
  indexedAt                DateTime  @default(now())
  stale                    Boolean   @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, nodeId])
  @@index([workspaceId, type, status])
}

model EdgeIndex {
  id            String   @id @default(uuid()) @db.Uuid
  workspaceId   String   @db.Uuid
  sourceNodeId  String
  targetNodeRef String
  targetNodeId  String?
  edgeType      String
  sourceField   String?
  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sourceNodeId, targetNodeRef, edgeType])
  @@index([workspaceId, sourceNodeId])
}

model TaskIndex {
  id               String    @id @default(uuid()) @db.Uuid
  workspaceId      String    @db.Uuid
  nodeId           String
  targetNodeId     String?
  targetSection    String?
  workflow         String
  title            String    @default("")
  instructions     String    @default("")
  priority         Int       @default(0)
  status           String    @default("open")
  assignedToUserId String?   @db.Uuid
  claimedSessionId String?
  leaseExpiresAt   DateTime?
  snoozedUntil     DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedTasks", fields: [assignedToUserId], references: [id])

  @@unique([workspaceId, nodeId])
  @@index([workspaceId, status, priority])
}

model Job {
  id              String    @id @default(uuid()) @db.Uuid
  workspaceId     String    @db.Uuid
  type            JobType
  status          JobStatus @default(queued)
  input           Json
  output          Json?
  error           String?
  createdByUserId String    @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  startedAt       DateTime?
  finishedAt      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("JobCreator", fields: [createdByUserId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String?  @db.Uuid
  userId      String?  @db.Uuid
  action      String
  targetType  String
  targetId    String?
  details     Json
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model LocalTheorem {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  leanName    String
  statement   String
  proofFile   String
  status      String
  nodeId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Project {
  id                       String        @id @default(uuid()) @db.Uuid
  workspaceId              String        @db.Uuid
  slug                     String
  title                    String
  area                     String?
  statement                String
  status                   ProjectStatus @default(seed)
  coordinatorSummary       String?
  currentWorkingPaperId    String?       @db.Uuid
  strategicReviewInterval  Int           @default(10)
  strategicReviewHardLimit Int           @default(15)
  createdByUserId          String?       @db.Uuid
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  goals                 ProjectGoal[]
  workstreams           Workstream[]
  agentRuns             AgentRun[]
  agentMessages         AgentMessage[]
  reports               WorkstreamReport[]
  reviews               ReviewRound[]
  artifacts             Artifact[]
  mathObjects           MathObject[]
  claims                Claim[]
  proofRoutes           ProofRoute[]
  proofAttempts         ProofAttempt[]
  gaps                  Gap[]
  counterexamples       Counterexample[]
  experiments           Experiment[]
  formalizationTargets  FormalizationTarget[]
  leanTheorems          LeanTheorem[]
  graphEdges            GraphEdge[]
  researchDeltas        ResearchDelta[]
  mechanisms            Mechanism[]
  originSpinouts        SpinoutCandidate[]         @relation("SpinoutOriginProject")
  promotedSpinouts      SpinoutCandidate[]         @relation("SpinoutPromotedProject")
  assumptionRegimes     AssumptionRegime[]
  theoremContracts      TheoremContract[]
  frontierSnapshots     ResearchFrontierSnapshot[]
  researchArtifacts     ResearchArtifact[]
  manuscriptVersions    ManuscriptVersion[]
  proofObligations      ProofObligation[]
  projectEpochs         ProjectEpoch[]
  strategicReviews      StrategicReviewRound[]
  externalReviewImports ExternalReviewImport[]
  branches              ProjectBranch[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model ProjectGoal {
  id               String            @id @default(uuid()) @db.Uuid
  workspaceId      String            @db.Uuid
  projectId        String            @db.Uuid
  title            String
  statement        String
  status           ProjectGoalStatus @default(proposed)
  priority         Int               @default(0)
  successCriteria  Json
  dependencies     Json
  approvedAt       DateTime?
  approvedByUserId String?           @db.Uuid
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  approvedBy  User?        @relation("GoalApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  workstreams Workstream[]

  @@index([workspaceId, projectId, status])
}

model Workstream {
  id                 String           @id @default(uuid()) @db.Uuid
  workspaceId        String           @db.Uuid
  projectId          String           @db.Uuid
  goalId             String?          @db.Uuid
  parentWorkstreamId String?          @db.Uuid
  title              String
  kind               WorkstreamKind
  coordinatorRole    AgentRole
  status             WorkstreamStatus @default(planned)
  priority           Int              @default(0)
  targetObjectType   String?
  targetObjectId     String?
  instructions       String
  allowedWrites      Json
  forbiddenActions   Json
  successCriteria    Json
  reportId           String?          @db.Uuid
  reviewPolicy       Json
  escalationMessage  String?
  assignedToUserId   String?          @db.Uuid
  claimedSessionId   String?
  leaseExpiresAt     DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  completedAt        DateTime?

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  goal          ProjectGoal?           @relation(fields: [goalId], references: [id], onDelete: SetNull)
  parent        Workstream?            @relation("WorkstreamChildren", fields: [parentWorkstreamId], references: [id], onDelete: SetNull)
  children      Workstream[]           @relation("WorkstreamChildren")
  assignedTo    User?                  @relation("AssignedWorkstreams", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  agentRuns     AgentRun[]
  messages      AgentMessage[]
  reports       WorkstreamReport[]
  reviews       ReviewRound[]
  artifacts     Artifact[]
  proofRoutes   ProofRoute[]
  proofAttempts ProofAttempt[]
  experiments   Experiment[]
  dependencies  WorkstreamDependency[] @relation("DependentWorkstream")
  dependents    WorkstreamDependency[] @relation("PrerequisiteWorkstream")

  @@index([workspaceId, projectId, status, priority])
  @@index([workspaceId, goalId])
}

model AgentRun {
  id                String         @id @default(uuid()) @db.Uuid
  workspaceId       String         @db.Uuid
  projectId         String         @db.Uuid
  workstreamId      String         @db.Uuid
  role              AgentRole
  status            AgentRunStatus @default(started)
  model             String?
  sessionId         String
  inputBriefing     Json
  outputSummary     String?
  toolCalls         Json
  createdObjectRefs Json
  updatedObjectRefs Json
  startedAt         DateTime       @default(now())
  finishedAt        DateTime?

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workstream   Workstream    @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  reviewRounds ReviewRound[]
  artifacts    Artifact[]

  @@index([workspaceId, workstreamId, status])
  @@index([workspaceId, projectId, startedAt])
}

model AgentMessage {
  id           String           @id @default(uuid()) @db.Uuid
  workspaceId  String           @db.Uuid
  projectId    String           @db.Uuid
  workstreamId String?          @db.Uuid
  fromRole     AgentRole
  toRole       AgentRole
  kind         AgentMessageKind
  body         String
  artifactRefs Json
  createdAt    DateTime         @default(now())

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workstream Workstream? @relation(fields: [workstreamId], references: [id], onDelete: SetNull)

  @@index([workspaceId, projectId, createdAt])
}

model WorkstreamReport {
  id               String                 @id @default(uuid()) @db.Uuid
  workspaceId      String                 @db.Uuid
  projectId        String                 @db.Uuid
  workstreamId     String                 @db.Uuid
  title            String
  status           WorkstreamReportStatus @default(draft)
  bodyMarkdown     String
  uncertaintyNotes Json
  linkedObjectRefs Json
  artifactRefs     Json
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  submittedAt      DateTime?

  workspace  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workstream Workstream    @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  reviews    ReviewRound[]

  @@index([workspaceId, workstreamId, status])
}

model ReviewRound {
  id                         String             @id @default(uuid()) @db.Uuid
  workspaceId                String             @db.Uuid
  projectId                  String             @db.Uuid
  workstreamId               String             @db.Uuid
  reportId                   String?            @db.Uuid
  targetObjectType           String
  targetObjectId             String
  reviewerRole               AgentRole
  verdict                    ReviewVerdict
  issues                     Json
  requiredChanges            Json
  checkedRefs                Json
  bodyMarkdown               String
  createdByAgentRunId        String?            @db.Uuid
  reviewType                 ReviewType         @default(legacy_unspecified)
  targetVersion              String?
  scope                      Json               @default("{}")
  inspectedArtifactIds       Json               @default("[]")
  checkedObligationIds       Json               @default("[]")
  parentMathReopenable       Boolean            @default(true)
  priorApprovalsEvidenceOnly Boolean            @default(true)
  independence               ReviewIndependence @default(same_workstream_reviewer)
  createdAt                  DateTime           @default(now())

  workspace         Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workstream        Workstream              @relation(fields: [workstreamId], references: [id], onDelete: Cascade)
  report            WorkstreamReport?       @relation(fields: [reportId], references: [id], onDelete: SetNull)
  createdByAgentRun AgentRun?               @relation(fields: [createdByAgentRunId], references: [id], onDelete: SetNull)
  obligationChecks  ReviewObligationCheck[]

  @@index([workspaceId, workstreamId, verdict])
  @@index([workspaceId, projectId, reviewType, targetVersion, verdict])
}

model ManuscriptVersion {
  id                   String                      @id @default(uuid()) @db.Uuid
  workspaceId          String                      @db.Uuid
  projectId            String                      @db.Uuid
  artifactId           String                      @db.Uuid
  version              Int
  contentHash          String
  theoremFingerprint   String
  citationFingerprint  String
  isCanonical          Boolean                     @default(false)
  verificationState    ManuscriptVerificationState @default(unverified_candidate)
  freezeLevel          ManuscriptFreezeLevel       @default(none)
  lexicalFrozenAt      DateTime?
  interfaceFrozenAt    DateTime?
  mathematicalFrozenAt DateTime?
  supersededAt         DateTime?
  createdAt            DateTime                    @default(now())

  workspace             Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project               Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact              ResearchArtifact            @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  obligations           ProofObligation[]
  externalReviewImports ExternalReviewImport[]
  physicalArtifacts     ArtifactManuscriptVersion[]

  @@unique([projectId, version])
  @@unique([projectId, contentHash])
  @@index([workspaceId, projectId, isCanonical])
}

model ProofObligation {
  id                          String   @id @default(uuid()) @db.Uuid
  workspaceId                 String   @db.Uuid
  projectId                   String   @db.Uuid
  manuscriptVersionId         String   @db.Uuid
  claimId                     String?  @db.Uuid
  title                       String
  statementMarkdown           String
  dependencies                Json     @default("[]")
  sourceArtifactId            String?  @db.Uuid
  proofLocation               String?
  manuscriptLocation          String?
  externalTheorems            Json     @default("[]")
  externalAssumptionsMatched  Boolean?
  exactManuscriptProofPresent Boolean?
  required                    Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  workspace         Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project           Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manuscriptVersion ManuscriptVersion       @relation(fields: [manuscriptVersionId], references: [id], onDelete: Cascade)
  claim             Claim?                  @relation(fields: [claimId], references: [id], onDelete: SetNull)
  sourceArtifact    ResearchArtifact?       @relation("ObligationSourceArtifact", fields: [sourceArtifactId], references: [id], onDelete: SetNull)
  checks            ReviewObligationCheck[]

  @@index([workspaceId, manuscriptVersionId])
  @@index([workspaceId, claimId])
}

model ReviewObligationCheck {
  id                String   @id @default(uuid()) @db.Uuid
  workspaceId       String   @db.Uuid
  reviewRoundId     String   @db.Uuid
  proofObligationId String   @db.Uuid
  status            String
  evidenceMarkdown  String?
  createdAt         DateTime @default(now())

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reviewRound     ReviewRound     @relation(fields: [reviewRoundId], references: [id], onDelete: Cascade)
  proofObligation ProofObligation @relation(fields: [proofObligationId], references: [id], onDelete: Cascade)

  @@unique([reviewRoundId, proofObligationId])
  @@index([workspaceId, proofObligationId, status])
}

model WorkstreamDependency {
  id                       String   @id @default(uuid()) @db.Uuid
  workspaceId              String   @db.Uuid
  dependentWorkstreamId    String   @db.Uuid
  prerequisiteWorkstreamId String   @db.Uuid
  createdAt                DateTime @default(now())

